{
  "manifest_version": 3,
  "name": "cart_maker",
  "version": "1.1.0",
  "description": "Splits your iHerb cart into multiple orders that each stay under the tax-free import limit while keeping iHerb's free-shipping minimum.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "cart_maker",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.iherb.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.iherb.com/cart*",
        "https://checkout.iherb.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.iherb.com/cart*",
        "https://checkout.iherb.com/*"
      ],
      "js": ["inject-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
